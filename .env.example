# =====================================================================
# Vigolo Lead Radar - Variables de entorno (ejemplo)
# Copiar este archivo a `.env` y completar con claves reales.
# Todas las variables expuestas al front deben empezar con VITE_.
# =====================================================================

# --- Google Places API (buscador de negocios real) ---
# Ver src/services/placesService.ts para el punto de conexion.
VITE_GOOGLE_PLACES_API_KEY=

# --- OpenAI API (generador de mensajes con IA) ---
# Ver src/services/aiService.ts para el punto de conexion.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini

# --- Datos del negocio del remitente (usado en los mensajes) ---
VITE_AGENCY_NAME=Vigolo Web Studio
VITE_AGENCY_SIGNATURE=Santiago - Vigolo Web Studio

# --- Fuente de datos: "mock" | "google" ---
# Con "mock" la app usa datos demo. Cambiar a "google" cuando la API este conectada.
VITE_DATA_SOURCE=mock

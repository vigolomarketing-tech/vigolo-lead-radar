# =====================================================================
# 2GTech3D Lead Radar — Variables de entorno (ejemplo)
# Copiar a `.env`. Todo lo expuesto al front empieza con VITE_.
# =====================================================================

# --- Providers de datos e IA ---
# 'mock'  = funciona 100% en el navegador (demo/offline).
# 'google'/'openai' = requieren un backend/proxy (VITE_API_BASE_URL) que
# guarde las API keys. NUNCA poner API keys reales en variables VITE_*.
VITE_DATA_PROVIDER=mock
VITE_AI_PROVIDER=mock

# Backend/proxy propio que habla con Google Places y OpenAI.
# Ej: https://2gtech3d-lead-radar-api.TU-SUBDOMINIO.workers.dev
VITE_API_BASE_URL=

# --- Datos de 2GTech3D (usados en mensajes y propuestas) ---
VITE_AGENCY_NAME=2GTech3D
VITE_AGENCY_SIGNATURE=Equipo Comercial — 2GTech3D
VITE_AGENCY_PHONE=+54 9 11 3145-4001
VITE_AGENCY_WHATSAPP=5491131454001
VITE_AGENCY_EMAIL=info@2gtech.com.ar
VITE_AGENCY_ADDRESS=Muñiz 1888, CABA (Flores)
VITE_AGENCY_SITE=https://www.2gtech3d.com

# --- CRM / valores (máquinas en ARS) ---
VITE_CURRENCY=ARS
VITE_DEFAULT_TICKET=12000000

# --- Deploy ---
# GitHub Pages (subruta): /vigolo-lead-radar/ · Vercel/raíz: /
VITE_BASE=/

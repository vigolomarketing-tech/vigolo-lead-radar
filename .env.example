# =====================================================================
# Vigolo Lead Radar — Variables de entorno (ejemplo)
# Copiar a `.env`. Todo lo expuesto al front empieza con VITE_.
# =====================================================================

# --- Providers de datos e IA ---
# 'mock'  = funciona 100% en el navegador (demo/offline).
# 'google'/'openai' = requieren un backend/proxy (VITE_API_BASE_URL) que
# guarde las API keys. NUNCA poner API keys reales en variables VITE_*.
VITE_DATA_PROVIDER=mock
VITE_AI_PROVIDER=mock

# Backend/proxy propio que habla con Google Places y OpenAI.
# Ej: https://api.vigolo.dev
VITE_API_BASE_URL=

# --- Datos de la agencia (usados en mensajes y auditorías) ---
VITE_AGENCY_NAME=Vigolo Web Studio
VITE_AGENCY_SIGNATURE=Santiago — Vigolo Web Studio

# --- CRM / valores ---
VITE_CURRENCY=USD
VITE_DEFAULT_TICKET=800

# --- Deploy ---
# GitHub Pages (subruta): /vigolo-lead-radar/ · Vercel/raíz: /
VITE_BASE=/
